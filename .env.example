# --- Backend ---

# Postgres connection. Assumes a host-installed Postgres 16 listening on 5432.
# Create the DB and role with: make db-create
DATABASE_URL=postgresql+psycopg://cs423:cs423@localhost:5432/cs423_grading

# Sepolia RPC. REQUIRED. The backend fails loudly at boot if this is missing.
# Replace YOUR_KEY with your Alchemy key. No public-RPC fallback.
SEPOLIA_RPC_URL=https://eth-sepolia.g.alchemy.com/v2/YOUR_KEY

# SIWE / session
SIWE_DOMAIN=localhost:5173
SIWE_URI=http://localhost:5173
SESSION_TTL_HOURS=12
NONCE_TTL_MINUTES=5
COOKIE_SECURE=false

# CORS — comma-separated origins the API accepts session cookies from
CORS_ALLOW_ORIGINS=http://localhost:5173

# --- Frontend ---
# Vite proxies /api/* → VITE_API_BASE in dev. Leave blank to use the proxy.
VITE_API_BASE=
